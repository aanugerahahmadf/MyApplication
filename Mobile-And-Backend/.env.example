APP_NAME="Dekorasi Bunga Pernikahan"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# ── Multi-Port Development Strategy ──────────────────────────────────────────
# This application supports running multiple platform modes simultaneously,
# each on a dedicated port to avoid conflicts:
#
#   Platform   Command                     Default Port  Config File
#   ─────────────────────────────────────────────────────────────────────────
#   Web        php artisan serve           8000          .env.web   (override)
#   Mobile     php artisan native:run      8001          .env.mobile (override)
#   Desktop    php artisan native:serve    8002          .env.desktop (override)
#
# To run in web mode:
#   php artisan serve --port=8000
#
# To run in mobile mode (uses NATIVE_SERVER_PORT from .env.mobile):
#   cp .env.mobile.example .env.mobile   # once, then edit as needed
#   php artisan native:run
#
# To run in desktop mode (uses NATIVEPHP_HTTP_PORT from .env.desktop):
#   cp .env.desktop.example .env.desktop  # once, then edit as needed
#   php artisan native:serve
#
# Platform-specific .env files are merged on top of this base .env at runtime.
# Platform-specific values take precedence over base values for the same key.
# See .env.web.example, .env.mobile.example, .env.desktop.example for details.
# ─────────────────────────────────────────────────────────────────────────────

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wedding_organizer
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME="Dekorasi Bunga Pernikahan"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=your-reverb-app-id
REVERB_APP_KEY=your-reverb-app-key
REVERB_APP_SECRET=your-reverb-app-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Pusher Channels configuration
# Get these values from your Pusher dashboard: https://dashboard.pusher.com
PUSHER_APP_ID=your-pusher-app-id
PUSHER_APP_KEY=your-pusher-key
PUSHER_APP_SECRET=your-pusher-secret
PUSHER_APP_CLUSTER=mt1
# Optional: custom host/port if using a Pusher-compatible server
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

AI_CORE_URL=http://127.0.0.1:5000
CBIR_API_URL=http://127.0.0.1:5000

# Mobile app config (GET /api/settings)
WEDDING_APP_NAME="Dekorasi Bunga Pernikahan"
WEDDING_APP_OWNER_NAME="Dekorasi Bunga Pernikahan"
WEDDING_APP_DEMO_VIDEO_URL=

NATIVEPHP_APP_ID=com.example.yourapp
NATIVEPHP_APP_VERSION="1.0.0"
NATIVEPHP_APP_VERSION_CODE="1"
NATIVEPHP_DEEPLINK_SCHEME=yourapp
NATIVEPHP_DEEPLINK_HOST=auth
NATIVEPHP_BUILD_TEMP_DIR=/tmp/nativephp-build
NATIVEPHP_ANDROID_MIN_SDK=31
# Android SDK on D: (required for native:run / emulator)
ANDROID_SDK_ROOT=D:\Android\Sdk
ANDROID_HOME=D:\Android\Sdk
ANDROID_AVD_HOME=D:\Android\avd
ANDROID_EMULATOR=D:\Android\Sdk\emulator\emulator.exe
NATIVEPHP_ANDROID_SDK_LOCATION=D:\Android\Sdk
NATIVEPHP_GRADLE_PATH=D:\Android\Sdk\jdk-26.0.1
NATIVEPHP_ANDROID_AVD=small_phone
JAVA_HOME=D:\Android\Sdk\jdk-26.0.1
NATIVE_HOST_IP=10.0.2.2
# Base server port for web mode (see multi-port strategy above).
# Override with NATIVE_SERVER_PORT=8001 in .env.mobile for mobile mode.
NATIVE_SERVER_PORT=8000
COMPOSER_PROCESS_TIMEOUT=0
NATIVE_DB_PROXY_SECRET=your-db-proxy-secret

FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://127.0.0.1:8000/auth/google/callback

FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
FACEBOOK_REDIRECT_URL=https://127.0.0.1:8000/auth/facebook/callback

# Midtrans Payment Gateway
# Daftar di: https://dashboard.sandbox.midtrans.com
MIDTRANS_MERCHANT_ID=your-midtrans-merchant-id
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

MIDTRANS_SNAP_BI_CLIENT_ID=
MIDTRANS_SNAP_BI_PRIVATE_KEY=
MIDTRANS_SNAP_BI_CLIENT_SECRET=
MIDTRANS_SNAP_BI_PARTNER_ID=
MIDTRANS_SNAP_BI_CHANNEL_ID=
MIDTRANS_SNAP_BI_PUBLIC_KEY=

# Android Keystore Configuration
ANDROID_KEYSTORE_FILE=app-release-key.jks
ANDROID_KEYSTORE_PASSWORD=your-keystore-password
ANDROID_KEY_ALIAS=app-key
ANDROID_KEY_PASSWORD=your-key-password

PLATFORM_PWA_ENABLED=true
PLATFORM_PWA_START_URL=/user

FONNTE_TOKEN=your-fonnte-token

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
FIREBASE_DATABASE_URL=https://your-firebase-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id
FIREBASE_CREDENTIALS_PATH=storage/app/firebase-credentials.json
FIREBASE_CACHE_TTL=3600
