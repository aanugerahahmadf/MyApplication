{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:web": "cross-env VITE_PLATFORM=web vite build",
        "build:mobile": "cross-env VITE_PLATFORM=mobile vite build",
        "build:mobile:ios": "cross-env VITE_PLATFORM=mobile vite build --mode=ios",
        "build:mobile:android": "cross-env VITE_PLATFORM=mobile vite build --mode=android",
        "build:desktop": "cross-env VITE_PLATFORM=desktop vite build",
        "build:all": "npm run build:web && npm run build:mobile && npm run build:desktop",
        "dev": "vite",
        "dev:web": "cross-env VITE_PLATFORM=web vite",
        "dev:mobile": "cross-env VITE_PLATFORM=mobile vite",
        "dev:mobile:ios": "cross-env VITE_PLATFORM=mobile vite --mode=ios",
        "dev:mobile:android": "cross-env VITE_PLATFORM=mobile vite --mode=android",
        "dev:desktop": "cross-env VITE_PLATFORM=desktop vite"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.15.2",
        "concurrently": "^9.0.1",
        "cross-env": "^7.0.3",
        "electron": "^42.3.3",
        "laravel-echo": "^2.3.0",
        "laravel-vite-plugin": "^2.0.0",
        "pusher-js": "^8.4.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "imports": {
        "#nativephp": "./vendor/nativephp/mobile/resources/dist/native.js"
    },
    "dependencies": {
        "@dataconnect/generated": "file:src/dataconnect-generated",
        "@google-cloud/api-gateway": "^4.2.2",
        "@google-cloud/bigquery-data-transfer": "^5.1.3",
        "@google-cloud/bigquery-reservation": "^4.4.1",
        "@google-cloud/language": "^7.2.2",
        "@google-cloud/retail": "^4.3.1",
        "@google-cloud/translate": "^9.4.1",
        "@google-cloud/vision": "^5.3.6",
        "@popperjs/core": "^2.11.8",
        "emoji-js": "^3.9.0",
        "emoji-picker-element": "^1.29.1",
        "firebase": "^10.8.0"
    }
}
